# =============================================================================
# Forge AI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public URL of the running app. Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Database (Neon / Postgres)
# -----------------------------------------------------------------------------
# Pooled connection (used by app at runtime). From Neon: "Pooled connection".
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
# Direct connection (used by Prisma migrations). From Neon: "Direct connection".
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# -----------------------------------------------------------------------------
# BetterAuth
# -----------------------------------------------------------------------------
# 32+ char random string. Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
# Must match your public app URL.
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# GitHub OAuth (used for sign-in AND for repo access)
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/github
# Scopes requested by BetterAuth provider config:
#   repo, read:user, user:email, admin:repo_hook
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# GitHub Webhooks
# Shared secret used to HMAC-sign webhook payloads.
# Generate: `openssl rand -hex 32`
# Set the same value when creating each repo webhook (or in your GitHub App).
# -----------------------------------------------------------------------------
GITHUB_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# GitHub App (OPTIONAL — only if you opt for the App route over OAuth)
# -----------------------------------------------------------------------------
# GITHUB_APP_ID=""
# GITHUB_APP_CLIENT_ID=""
# GITHUB_APP_CLIENT_SECRET=""
# Base64-encoded PEM contents of the GitHub App private key.
# Encode: `cat private-key.pem | base64`
# GITHUB_APP_PRIVATE_KEY_BASE64=""

# -----------------------------------------------------------------------------
# Mistral AI (via Vercel AI SDK)
# Get key: https://console.mistral.ai/api-keys
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=""
# Optional overrides — defaults in code: mistral-small-latest for both
# MISTRAL_MODEL_HEAVY="mistral-small-latest"
# MISTRAL_MODEL_CHEAP="mistral-small-latest"

# -----------------------------------------------------------------------------
# Inngest
# Local dev: leave EVENT_KEY/SIGNING_KEY blank, the Inngest dev server handles it.
# Production: get keys from https://app.inngest.com (Settings → Keys)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# Optional: explicitly name the Inngest app (defaults to "forge-ai")
# INNGEST_APP_ID="forge-ai"

# -----------------------------------------------------------------------------
# Razorpay (Billing)
# Test mode: https://dashboard.razorpay.com/app/keys (toggle Test Mode)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Webhook signing secret — set when you create the webhook in Razorpay dashboard.
RAZORPAY_WEBHOOK_SECRET=""
# Plan IDs — create plans in Razorpay dashboard and paste IDs here.
RAZORPAY_PLAN_PRO=""
RAZORPAY_PLAN_TEAM=""
# Expose key id to client (Razorpay Checkout needs it in the browser)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# -----------------------------------------------------------------------------
# Optional: Upstash Redis (for rate limiting — stretch goal)
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Optional: PostHog / analytics
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# -----------------------------------------------------------------------------
# Encryption key for storing third-party tokens (GitHub access tokens, etc.)
# Generate: `openssl rand -base64 32`
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=""
